{
        "schemaVersion": 1,
        "id": "migalib",
        "name": "MIGA Library",
        "version": "0.0-ALPHA",

        "license": "MIT",

        "environment": "*",

        "entrypoints": {
                "main": [
                        "go.sinzchr.migalib.MigaLib"
                ],
                "client": [
                        "go.sinzchr.migalib.MigaLibClient"
                ]
        },

        "mixins": [
                "mixins.json",
                {
                        "config": "client.mixins.json",
                        "environment": "client"
                }
        ],

        "depends": {
                "java": ">=21",
                "minecraft": "~1.20.1",
                "fabricloader": ">=0.17.3",
                "fabric-api": ">=0.92.6",
                "fabric-key-binding-api-v1": "*"
        }
}